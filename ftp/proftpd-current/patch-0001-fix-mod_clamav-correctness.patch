+static int write_all(int fd, const void *buf, size_t len);
 
+static int write_all(int fd, const void *buf, size_t len) {
+  const unsigned char *ptr = (const unsigned char *) buf;
+  size_t off = 0;
+
+  while (off < len) {
+    ssize_t nwritten = write(fd, ptr + off, len - off);
+    if (nwritten < 0) {
+      if (errno == EINTR)
+        continue;
+      return -1;
+    }
+    if (nwritten == 0) {
+      errno = EPIPE;
+      return -1;
+    }
+    off += (size_t) nwritten;
+  }
+
+  return 0;
+}
