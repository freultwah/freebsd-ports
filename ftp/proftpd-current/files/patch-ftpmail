+        except Exception as e:
+            logging.error(f"Error reading from FIFO: {e}")
+            time.sleep(float(config.get('sleep', 0.5)))
+
+    fifo.close()
+    if xferlog_fh:
+        try:
+            xferlog_fh.close()
+        except Exception:
+            pass
+
+def main():
+    config_file_path = parse_config_path() or default_config_path()
+    config = load_config_file(config_file_path)
+    config = parse_arguments(config)
+    preflight_config(config)
+    run_service(config)
+
+def preflight_config(config):
+    log_path = config.get('log', '/var/log/ftpmail.log')
+    if log_path:
+        try:
+            with open(log_path, 'a'):
+                pass
+        except Exception as e:
+            print(f"Unable to open log file '{log_path}': {e}", file=sys.stderr)
+            sys.exit(1)
+
+    xferlog_path = config.get('xferlog', '/var/log/proftpd/xferlog')
+    if xferlog_path:
+        try:
+            with open(xferlog_path, 'a'):
+                pass
+        except Exception as e:
+            print(f"Unable to open xferlog file '{xferlog_path}': {e}", file=sys.stderr)
+            sys.exit(1)
+
+def run_service(config):
+    log_level = get_log_level(config.get('log_level', 'info'))
+    log_format = config.get('log_format', 'full')
+    setup_logging(config.get('log'), log_level, log_format)
+
+    signal_state = {'reopen_logs': False}
+
+    def handle_exit(signum, frame):
+        logging.info(f"Received signal {signum}. Exiting.")
+        sys.exit(0)
+
+    def handle_hup(signum, frame):
+        signal_state['reopen_logs'] = True
+
+    signal.signal(signal.SIGTERM, handle_exit)
+    signal.signal(signal.SIGINT, handle_exit)
+    signal.signal(signal.SIGHUP, handle_hup)
+
+    monitor_fifo(config, signal_state)
