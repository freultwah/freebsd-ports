PORTNAME=	phpldapadmin
DISTVERSION=	2.3.11
PORTREVISION=	0
CATEGORIES=	net www
PKGNAMESUFFIX=	${PHP_PKGNAMESUFFIX}
DEPS_DISTFILE=	${PORTNAME}-${DISTVERSION}-deps${EXTRACT_SUFX}

.if make(make-deps-distfile)
BUILD_DEPENDS+=	npm${NODEJS_SUFFIX}>0:www/npm${NODEJS_SUFFIX} \
		${LOCALBASE}/bin/composer:devel/php-composer@${PHP_FLAVOR}
.endif

MAINTAINER=	raivo@lehma.com
COMMENT=	PHP application to administer LDAP over the web
WWW=		http://phpldapadmin.sourceforge.net/

LICENSE=	GPLv2
LICENSE_FILE=	${WRKSRC}/LICENSE

USES=		cpe php:web,flavors tar:tgz
.if make(make-deps-distfile)
USES+=		nodejs:lts,build
.endif
CPE_VENDOR=	phpldapadmin_project
USE_GITHUB=	yes
GH_ACCOUNT=	leenooks
GH_PROJECT=	phpLDAPadmin
USE_PHP=	ctype dom fileinfo filter gettext hash iconv igbinary ldap mbstring openssl pcre session sqlite3 tokenizer xml xmlwriter

NO_ARCH=	yes
NO_BUILD=	yes

OPTIONS_DEFINE=	MCRYPT
MCRYPT_DESC=	Use pecl-mcrypt for password hashing
MCRYPT_USE=	PHP=mcrypt

PLIST=		${WRKDIR}/plist

.include <bsd.port.options.mk>

USERS?=		${WWWOWN}
GROUPS?=	${WWWGRP}

.if !make(make-deps-distfile) && !defined(SKIP_DEPS_DISTFILE)
post-patch:
	@${TAR} -xf ${DISTDIR}/${DEPS_DISTFILE} -C ${WRKSRC}
.endif

# Install phase: Copy all files, including those generated by npm
do-install:
	@${MKDIR} ${STAGEDIR}${WWWDIR}
	@cd ${WRKSRC} && \
		${FIND} . \
			-not -path "*/.git*" \
			-not -path "*/node_modules*" \
			-not -path "*/docker*" \
			-not -name ".dockerignore" \
			-not -name ".editorconfig" \
			-not -name "composer.lock" \
			-not -name "package.json" \
			-not -name "package-lock.json" \
			-not -name "*.orig" \
			-print | ${CPIO} -pdm ${STAGEDIR}${WWWDIR}
	@find ${STAGEDIR}${WWWDIR} -type d -exec chmod 755 {} +
	@find ${STAGEDIR}${WWWDIR} -type f -exec chmod 644 {} +

post-install:
	@${ECHO_MSG} "Generating dynamic plist..."
	@cd ${STAGEDIR}${PREFIX} && \
		${FIND} ${WWWDIR:S,${PREFIX}/,,} -type f -o -type l | sort > ${WRKDIR}/plist.files && \
		${FIND} ${WWWDIR:S,${PREFIX}/,,} -type d | sort -r | ${SED} 's,^,@dir ,' > ${WRKDIR}/plist.dirs && \
		echo "@owner ${WWWOWN}" > ${TMPPLIST} && \
		echo "@group ${WWWGRP}" >> ${TMPPLIST} && \
		cat ${WRKDIR}/plist.files ${WRKDIR}/plist.dirs >> ${TMPPLIST}

# Maintainer target: run with network access to refresh the offline build artifact.
# Keep ${DISTDIR}/${DEPS_DISTFILE} available for normal stage/package builds.
make-deps-distfile: build-depends
	@cd ${.CURDIR} && ${MAKE} SKIP_DEPS_DISTFILE=yes patch
	@cd ${WRKSRC} && ${RM} -rf node_modules vendor public/css/app.css public/fonts public/js/app.js public/js/manifest.js public/js/vendor.js public/mix-manifest.json public/webfonts
	@cd ${WRKSRC} && ${SETENV} ${MAKE_ENV} composer install --no-dev --no-interaction --no-progress --prefer-dist
	@cd ${WRKSRC} && ${SETENV} ${MAKE_ENV} npm ci
	@cd ${WRKSRC} && ${SETENV} ${MAKE_ENV} npm run prod
	@cd ${WRKSRC} && ${RM} -rf node_modules
	@cd ${WRKSRC} && ${TAR} -czf ${DISTDIR}/${DEPS_DISTFILE} vendor public
	@${ECHO_MSG} "Created ${DISTDIR}/${DEPS_DISTFILE}"

.include <bsd.port.pre.mk>

.include <bsd.port.post.mk>
