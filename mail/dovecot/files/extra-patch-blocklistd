+static bool
+client_auth_is_blocklistd_failure(enum client_auth_fail_code fail_code)
+{
+	switch (fail_code) {
+	case CLIENT_AUTH_FAIL_CODE_NONE:
+		return TRUE;
+	case CLIENT_AUTH_FAIL_CODE_AUTHZFAILED:
+	case CLIENT_AUTH_FAIL_CODE_TEMPFAIL:
+	case CLIENT_AUTH_FAIL_CODE_USER_DISABLED:
+	case CLIENT_AUTH_FAIL_CODE_PASS_EXPIRED:
+	case CLIENT_AUTH_FAIL_CODE_INVALID_BASE64:
+	case CLIENT_AUTH_FAIL_CODE_LOGIN_DISABLED:
+	case CLIENT_AUTH_FAIL_CODE_MECH_INVALID:
+	case CLIENT_AUTH_FAIL_CODE_MECH_SSL_REQUIRED:
+	case CLIENT_AUTH_FAIL_CODE_ANONYMOUS_DENIED:
+		return FALSE;
+	}
+	return FALSE;
+}
+
+static void
+client_auth_blocklist_notify(struct client *client,
+			     const struct client_auth_reply *reply)
+{
+	enum client_auth_fail_code fail_code = reply == NULL ?
+		CLIENT_AUTH_FAIL_CODE_NONE : reply->fail_code;
+
+	if (client->fd == -1 ||
+	    !client_auth_is_blocklistd_failure(fail_code))
+		return;
+
+	pfilter_notify(1, client->fd, login_binary->protocol);
+}
