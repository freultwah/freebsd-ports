--- src/login-common/pfilter.c.orig
+++ src/login-common/pfilter.c
@@ -0,0 +1,38 @@
+/* Copyright (c) 2026 Dovecot authors, see the included COPYING file */
+
+#include "pfilter.h"
+
+#ifdef USE_BLOCKLISTD
+
+#include <stdio.h> /* for NULL */
+#include <blocklist.h>
+
+static struct blocklist *blstate;
+
+void pfilter_notify(int action, int fd, const char *service)
+{
+	if (service == NULL)
+		service = "dovecot-login";
+
+	if (blstate == NULL)
+		blstate = blocklist_open();
+	if (blstate == NULL)
+		return;
+
+	(void)blocklist_r(blstate, action, fd, service);
+	if (action == 0) {
+		blocklist_close(blstate);
+		blstate = NULL;
+	}
+}
+
+#else
+
+void pfilter_notify(int action, int fd, const char *service)
+{
+	(void)action;
+	(void)fd;
+	(void)service;
+}
+
+#endif
--- src/login-common/pfilter.h.orig
+++ src/login-common/pfilter.h
@@ -0,0 +1 @@
+void pfilter_notify(int action, int fd, const char *service);
